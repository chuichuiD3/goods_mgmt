// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MerchantPreorderStatus {
  ordered
  pending_final_payment
  fully_paid
  received
}

enum MerchantPreorderSubtype {
  full_payment_presale
  deposit_presale
}

enum MerchantPreorderGroupStatus {
  open
  received
  cancelled
}

enum HoldingOrderStatus {
  holding
  ready_to_ship
  shipped
  received
}

enum HoldingOrderTimeMode {
  duration
  fixed_date
  none
}

model Auction {
  id             Int       @id @default(autoincrement())
  itemName       String
  series         String?
  character      String?
  category       String?
  platform       String?
  auctionUrl     String?
  currentPrice   Float?
  myMaxBid       Float?
  auctionEndTime DateTime?
  imageUrl       String?
  imageThumbUrl  String?
  status         String    @default("WATCHING")
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model WishlistItem {
  id             Int       @id @default(autoincrement())
  itemName       String
  series         String?
  character      String?
  category       String?
  sourcePlatform String?
  sourceUrl      String?
  expectedPrice  Float?
  imageUrl       String?
  priority       String    @default("MEDIUM")
  notes          String?
  addedAt        DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Item {
  id             Int       @id @default(autoincrement())
  itemName       String
  series         String?
  character      String?
  category       String?
  platform       String?
  shop           String?
  price          Float
  quantity       Int       @default(1)
  totalAmount    Float
  currency       String    @default("JPY")
  status         String    @default("PENDING_PAYMENT")
  orderDate      DateTime?
  paymentDeadline DateTime?
  paidAt         DateTime?
  isPresale      Boolean   @default(false)
  sourceType     String   @default("DIRECT_PURCHASE")
  sourceOrderId  String?
  imageUrl       String?
  imageThumbUrl  String?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model ImportDraft {
  id           Int            @id @default(autoincrement())
  sourceUrl    String
  platform     String?
  rawTitle     String?
  rawPrice     String?
  rawImage     String?
  detectedType String   @default("UNKNOWN")
  parseStatus  String   @default("PARTIAL")
  rawPayload   String?
  createdAt    DateTime        @default(now())
}

model MerchantPreorderItem {
  id           Int                    @id @default(autoincrement())
  name         String
  imageUrl     String?
  sellerName   String
  platform     String?
  purchaseDate DateTime
  amountPaid   Float?
  subtype      MerchantPreorderSubtype @default(full_payment_presale)
  quantity     Int                    @default(1)
  // Deposit-presale factual fields (future timing is often unknown)
  depositPaidAt DateTime?
  depositAmount Float?
  finalPaid     Boolean              @default(false)
  finalPaidAt   DateTime?
  finalAmount   Float?
  owned         Boolean              @default(false)
  status       MerchantPreorderStatus @default(ordered)
  note         String?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
}

model MerchantPreorderGroup {
  id            Int                     @id @default(autoincrement())
  sellerName    String
  platform      String?
  purchaseDate  DateTime
  // TEMP (legacy): will be migrated to line items, then removed
  subtype       MerchantPreorderSubtype @default(full_payment_presale)
  amountPaid    Float?
  depositPaidAt DateTime?
  depositAmount Float?
  finalPaid     Boolean                @default(false)
  finalPaidAt   DateTime?
  finalAmount   Float?
  owned         Boolean                @default(false)

  status        MerchantPreorderGroupStatus @default(open)
  notes         String?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  items         MerchantPreorderLineItem[]
}

model MerchantPreorderLineItem {
  id         Int                  @id @default(autoincrement())
  groupId    Int
  title      String
  imageUrl   String?
  quantity   Int                  @default(1)
  notes      String?

  // Transaction details are item-level
  subtype      MerchantPreorderSubtype @default(full_payment_presale)
  amountPaidTotal Float?
  currency     String               @default("JPY")

  // Deposit-presale factual fields
  depositPaidAt DateTime?
  depositAmount Float?
  finalPaid     Boolean              @default(false)
  finalPaidAt   DateTime?
  finalAmount   Float?
  owned         Boolean              @default(false)

  // Optional expected timing (not commitments)
  expectedReleaseAt DateTime?
  expectedShipAt    DateTime?

  received   Boolean              @default(false)
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  group      MerchantPreorderGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model HoldingOrderGroup {
  id                Int               @id @default(autoincrement())
  sellerName        String
  platform          String?
  purchaseDate      DateTime          @default(now())
  timeMode          HoldingOrderTimeMode @default(duration)
  durationDays      Int?
  deadline          DateTime?
  computedDeadline  DateTime?
  shippingThreshold Float?
  status            HoldingOrderStatus @default(holding)
  note              String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  items             HoldingOrderItem[]
}

model HoldingOrderItem {
  id       Int              @id @default(autoincrement())
  groupId  Int
  name     String
  imageUrl String?
  price    Float
  quantity Int              @default(1)

  group    HoldingOrderGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
}
